## ─── ThinkCode .env.example ───────────────────────────────────────────────
## Bu dosyayı kopyalayıp .env olarak kaydedin:
##   cp .env.example .env
## Ardından gerçek değerleri doldurun.

# ── OpenAI ──────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-proj-...

# ── Langfuse (isteğe bağlı) ────────────────────────────────────────────────
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_HOST=https://cloud.langfuse.com

# ── Gemini (isteğe bağlı) ──────────────────────────────────────────────────
GEMINI_API_KEY=

# ── PostgreSQL ──────────────────────────────────────────────────────────────
DB_HOST=127.0.0.1
DB_PORT=5433
DB_USERNAME=myuser
DB_PASSWORD=mypassword
DB_DATABASE=thinkcode_db

# ── JWT ─────────────────────────────────────────────────────────────────────
JWT_SECRET_KEY=thinkcode-super-secret-change-in-prod

# ── pgAdmin ─────────────────────────────────────────────────────────────────
PGADMIN_EMAIL=admin@admin.com
PGADMIN_PASSWORD=admin
PGADMIN_HOST_PORT=5050
PGADMIN_CONTAINER_PORT=80